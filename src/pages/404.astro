---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Word Not Found | arth';
const description = 'The requested word was not found in the dictionary.';
---

<BaseLayout title={title} description={description}>
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
    <div class="text-6xl mb-4">📖</div>
    <h1 class="text-3xl font-bold text-gray-900 mb-4">Word Not Found</h1>
    <p class="text-gray-600 mb-8 max-w-md">
      We couldn't find "{Astro.url.pathname.split('/').pop()}" in our dictionary. It might be
      spelled differently or not yet added.
    </p>

    <div class="space-y-4">
      <a
        href="/"
        class="inline-flex items-center gap-2 bg-primary-500 text-white px-6 py-3 rounded-lg hover:bg-primary-600 transition-colors"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
        Search Dictionary
      </a>

      <p class="text-sm text-gray-500">
        Try searching with different transliteration<br />
        or use Devanagari script
      </p>
    </div>
  </div>
</BaseLayout>
