---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SearchContainer from '@/components/SearchContainer';
---

<BaseLayout>
  <div class="flex flex-col items-center min-h-[60vh]">
    <a href="/">
      <h1 class="text-6xl font-bold text-taupe-500 mb-2 hover:text-primary-600 transition-colors">arth</h1>
    </a>
    <p class="text-lg text-gray-600 mb-8">Search in Devanagari, Roman, or English</p>

    <div class="w-full max-w-2xl mb-8">
      <SearchContainer client:load />
    </div>

    <div class="mt-12 text-center text-gray-500">
      <p class="mb-2">Try searching for:</p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a
          href="/word/नमस्ते"
          class="px-4 py-2 bg-white border border-gray-300 rounded-lg hover:border-primary-500 hover:text-primary-600 transition-colors font-hindi"
        >
          नमस्ते
        </a>
        <a
          href="/word/चम्मच"
          class="px-4 py-2 bg-white border border-gray-300 rounded-lg hover:border-primary-500 hover:text-primary-600 transition-colors font-hindi"
        >
          चम्मच
        </a>
        <a
          href="/word/धन्यवाद"
          class="px-4 py-2 bg-white border border-gray-300 rounded-lg hover:border-primary-500 hover:text-primary-600 transition-colors font-hindi"
        >
          धन्यवाद
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
