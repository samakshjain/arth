---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout>
  <div class="flex flex-col items-center justify-center min-h-[60vh]">
    <h1 class="text-4xl font-bold text-gray-900 mb-2">arth</h1>
    <p class="text-lg text-gray-600 mb-8">Search in Devanagari, Roman, or English</p>

    <div class="w-full max-w-2xl">
      <div class="relative">
        <input
          type="text"
          placeholder="Type a Hindi word, transliteration, or English meaning..."
          class="w-full px-6 py-4 text-lg border-2 border-gray-300 rounded-xl focus:border-primary-500 focus:outline-none font-hindi"
        />
        <button
          type="button"
          class="absolute right-3 top-1/2 -translate-y-1/2 bg-primary-500 text-white px-6 py-2 rounded-lg hover:bg-primary-600 transition-colors"
        >
          Search
        </button>
      </div>
    </div>

    <div class="mt-12 text-center text-gray-500">
      <p class="mb-2">Try searching for:</p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a
          href="/word/नमस्ते"
          class="px-4 py-2 bg-white border border-gray-300 rounded-lg hover:border-primary-500 hover:text-primary-600 transition-colors font-hindi"
        >
          नमस्ते
        </a>
        <a
          href="/word/चम्मच"
          class="px-4 py-2 bg-white border border-gray-300 rounded-lg hover:border-primary-500 hover:text-primary-600 transition-colors font-hindi"
        >
          चम्मच
        </a>
        <a
          href="/word/धन्यवाद"
          class="px-4 py-2 bg-white border border-gray-300 rounded-lg hover:border-primary-500 hover:text-primary-600 transition-colors font-hindi"
        >
          धन्यवाद
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
