---
import BaseLayout from '@/layouts/BaseLayout.astro';
import EntryDisplay from '@/components/EntryDisplay';
import type { DictionaryEntry } from '@/types';

// Generate static paths for all words
export async function getStaticPaths() {
  // Read dictionary data at build time
  const fs = await import('fs');
  const path = await import('path');

  const dictionaryPath = path.join(process.cwd(), 'src', 'data', 'dictionary.jsonl');
  const fileContent = fs.readFileSync(dictionaryPath, 'utf-8');

  const entries: DictionaryEntry[] = [];
  const seenWords = new Set<string>();

  for (const line of fileContent.split('\n')) {
    const trimmed = line.trim();
    if (!trimmed) continue;

    try {
      const entry = JSON.parse(trimmed) as DictionaryEntry;
      // Only include first occurrence of each word
      if (!seenWords.has(entry.word)) {
        seenWords.add(entry.word);
        entries.push(entry);
      }
    } catch {
      continue;
    }
  }

  return entries.map((entry) => ({
    params: { word: entry.word },
    props: { entry },
  }));
}

interface Props {
  entry: DictionaryEntry;
}

const { entry } = Astro.props;

// Build page title and description
const firstDef = entry.definitions[0];
const title = `${entry.word} (${entry.transliteration}) - ${firstDef?.meaning || 'Hindi Word'} | arth`;
const description = `Meaning of ${entry.word} (${entry.transliteration}): ${entry.definitions.map((d) => d.meaning).join('; ')}`;
---

<BaseLayout title={title} description={description}>
  <div class="max-w-3xl mx-auto">
    {/* Breadcrumb */}
    <nav class="mb-6 text-sm text-gray-500" aria-label="Breadcrumb">
      <ol class="flex items-center space-x-2">
        <li>
          <a href="/" class="hover:text-primary-600 transition-colors">Home</a>
        </li>
        <li aria-hidden="true">/</li>
        <li class="text-gray-900 font-medium" aria-current="page">{entry.word}</li>
      </ol>
    </nav>

    {/* Entry Display */}
    <EntryDisplay entry={entry} client:load />

    {/* Back to search */}
    <div class="mt-8 text-center">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-primary-600 hover:text-primary-700 transition-colors"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to search
      </a>
    </div>
  </div>
</BaseLayout>
