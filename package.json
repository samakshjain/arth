{
  "name": "arth",
  "type": "module",
  "version": "0.1.0",
  "description": "Clean, fast Hindi-English dictionary with client-side search",
  "scripts": {
    "dev": "astro dev",
    "build": "npm run build:data && astro build",
    "build:data": "echo 'Using existing data chunks'",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "prettier --check . && astro check",
    "lint:fix": "prettier --write .",
    "typecheck": "astro check",
    "check": "npm run lint && npm run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:python": "python3 tests/test_fuzzy_generator.py"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^6.0.0",
    "fuse.js": "^7.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/react": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
